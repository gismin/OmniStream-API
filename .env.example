# OmniStream-API Environment Variables
# Copy this file to .env and fill in your values

# ── Database (SQLite for dev, PostgreSQL for prod) ────────────────────────────
DATABASE_URL=sqlite:///./omnistream.db
# DATABASE_URL=postgresql://omnistream:changeme@localhost:5432/omnistream

# ── PostgreSQL (docker-compose only) ─────────────────────────────────────────
POSTGRES_DB=omnistream
POSTGRES_USER=omnistream
POSTGRES_PASSWORD=changeme

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:5174

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
